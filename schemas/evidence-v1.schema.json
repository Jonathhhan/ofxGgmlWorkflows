{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jonathhhan/ofxGgmlWorkflows/schemas/evidence-v1.schema.json",
  "title": "ofxGgml Evidence v1",
  "description": "Neutral evidence artifact schema for smoke builds, runtime checks, reports, and backend certification.",
  "oneOf": [
    {
      "$ref": "#/$defs/evidence"
    },
    {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidence"
      }
    }
  ],
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "repo",
        "lane",
        "commit_sha",
        "workflow_name",
        "runner_os",
        "backend",
        "result",
        "timestamp",
        "artifact_path"
      ],
      "properties": {
        "schema_version": {
          "description": "Evidence schema version. Use 1 for this schema.",
          "oneOf": [
            {
              "type": "string",
              "const": "1"
            },
            {
              "type": "integer",
              "const": 1
            }
          ]
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "lane": {
          "type": "string",
          "minLength": 1
        },
        "commit_sha": {
          "type": "string",
          "minLength": 7
        },
        "workflow_name": {
          "type": "string",
          "minLength": 1
        },
        "runner_os": {
          "type": "string",
          "minLength": 1
        },
        "backend": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "skipped",
            "not_certified"
          ]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "artifact_path": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string"
        },
        "certification_level": {
          "type": "string",
          "enum": [
            "declared",
            "smoke-built",
            "runtime-certified",
            "release-gated"
          ]
        },
        "tool_versions": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "boolean",
              "null"
            ]
          }
        },
        "device_summary": {
          "type": [
            "string",
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "reason_code": {
          "type": "string"
        },
        "workflow_run_id": {
          "type": [
            "string",
            "integer"
          ]
        },
        "workflow_run_attempt": {
          "type": [
            "string",
            "integer"
          ]
        },
        "workflow_ref": {
          "type": "string",
          "minLength": 1
        },
        "workflow_sha": {
          "type": "string",
          "minLength": 7
        },
        "job_name": {
          "type": "string",
          "minLength": 1
        },
        "matrix_os": {
          "type": "string",
          "minLength": 1
        },
        "runner_labels": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ]
        },
        "event_name": {
          "type": "string",
          "minLength": 1
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "producer_version": {
          "type": "string",
          "minLength": 1
        },
        "command_exit_code": {
          "type": "integer"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "tree_state": {
          "type": "string",
          "enum": [
            "clean",
            "dirty",
            "generated-only",
            "unknown"
          ]
        },
        "base_commit_sha": {
          "type": "string",
          "minLength": 7
        },
        "working_tree_patch_hash": {
          "type": "string",
          "minLength": 1
        },
        "untracked_count": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "subject_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
