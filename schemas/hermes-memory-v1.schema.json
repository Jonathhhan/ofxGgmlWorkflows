{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hermes Memory Index v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "repo",
    "commit_sha",
    "tree_state",
    "records"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "repo": {
      "type": "string",
      "minLength": 1
    },
    "commit_sha": {
      "type": "string",
      "minLength": 7
    },
    "tree_state": {
      "type": "string",
      "enum": [
        "clean",
        "dirty",
        "unknown",
        "generated-only"
      ]
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/memory_record"
      }
    }
  },
  "$defs": {
    "memory_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source_path",
        "repo",
        "lane",
        "source_type",
        "freshness",
        "summary",
        "retrieval_tags"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "source_path": {
          "type": "string",
          "minLength": 1
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "lane": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "type": "string",
          "enum": [
            "instruction",
            "workflow",
            "runtime",
            "evidence",
            "validation",
            "planning",
            "release",
            "security",
            "example",
            "memory"
          ]
        },
        "freshness": {
          "type": "string",
          "format": "date-time"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "retrieval_tags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    }
  }
}
